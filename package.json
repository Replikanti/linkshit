{
  "name": "linkshit",
  "version": "0.1.0",
  "description": "Linkshit — auto-scroll your LinkedIn feed and surface posts matching your criteria via a local LLM.",
  "main": "score-server.js",
  "scripts": {
    "start": "node score-server.js",
    "check": "node --check score-server.js && node --check content.js",
    "validate": "node -e \"['manifest.json','package.json'].forEach(f => JSON.parse(require('fs').readFileSync(f,'utf8')))\"",
    "lint": "eslint .",
    "pack": "node scripts/pack.js",
    "smoke": "node scripts/smoke-server.js",
    "audit": "npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "web-ext": "^10.1.0"
  }
}
